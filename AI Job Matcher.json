    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const jobs = $json.jobs;\n\nif (!jobs || jobs.length === 0) {\n  return {\n    json: {\n      subject: 'Daily Job Digest - No Matches Today',\n      body: '<h2>Daily Job Digest</h2><p>No jobs matched your criteria today. Check back tomorrow!</p>'\n    }\n  };\n}\n\n// Sort jobs by fit score\nconst sortedJobs = jobs.sort((a, b) => b.fit_score - a.fit_score);\n\n// Build email\nlet emailBody = `\n<h2>🎯 Daily Job Digest - ${new Date().toLocaleDateString()}</h2>\n<p>Found <strong>${jobs.length}</strong> matching job(s).</p>\n<hr>\n`;\n\nsortedJobs.forEach((job, index) => {\n  emailBody += `\n<div style=\"margin-bottom:20px;padding:15px;border-left:4px solid #4CAF50;\">\n  <h3>${index + 1}. ${job.job_title} at ${job.company}</h3>\n\n  <p><strong>📍 Location:</strong> ${job.location || 'Not specified'}</p>\n\n  <p><strong>🎯 Fit Score:</strong> ${job.fit_score}/100</p>\n\n  <p><strong>💡 Why it matches:</strong> ${job.reasoning}</p>\n\n  <p>\n    <a href=\"${job.apply_link}\">\n      Apply Here\n    </a>\n  </p>\n</div>\n`;\n});\n\nemailBody += `\n<hr>\n<p style=\"color:#666;font-size:12px;\">\nGenerated by AI Job Matcher\n</p>\n`;\n\nreturn {\n  json: {\n    subject: `Daily Job Digest - ${jobs.length} Match${jobs.length > 1 ? 'es' : ''} Found`,\n    body: emailBody\n  }\n};"
      },
